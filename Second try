        function switchLanguage(lang) {
            const html = document.documentElement;
            html.setAttribute('lang', lang);
            html.setAttribute('dir', lang === 'ar' ? 'rtl' : 'ltr');
            document.querySelectorAll('.lang-btn').forEach(btn => { btn.classList.remove('active', 'bg-edu-blue-600', 'text-white'); btn.classList.add('text-gray-600', 'hover:text-edu-blue-600'); });
            const activeBtn = document.querySelector(`.lang-btn-${lang}`);
            if(activeBtn) { activeBtn.classList.add('active', 'bg-edu-blue-600', 'text-white'); activeBtn.classList.remove('text-gray-600', 'hover:text-edu-blue-600'); }
            const trans = translations[lang];
            document.querySelectorAll('[data-i18n]').forEach(el => { const key = el.getAttribute('data-i18n'); if(trans[key]) { if(key === 'heroTitle') el.innerHTML = trans[key]; else el.textContent = trans[key]; } });
            document.querySelectorAll('.nav-links a, .cta-btn').forEach(link => { if(link.dataset[lang]) link.textContent = link.dataset[lang]; });
            localStorage.setItem('preferredLanguage', lang);
        }
        document.querySelectorAll('a[href^="#"]').forEach(anchor => { anchor.addEventListener('click', function(e) { e.preventDefault(); const target = document.querySelector(this.getAttribute('href')); if(target) target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }); });
        function toggleFAQ(button) { const content = button.nextElementSibling; const icon = button.querySelector('svg'); content.classList.toggle('hidden'); icon.classList.toggle('rotate-180'); }
        document.getElementById('contactForm')?.addEventListener('submit', function(e) { e.preventDefault(); const successMsg = document.getElementById('successMessage'); if(successMsg) { successMsg.classList.add('show'); this.reset(); setTimeout(() => successMsg.classList.remove('show'), 10000); } });
        window.addEventListener('DOMContentLoaded', function() { const savedLang = localStorage.getItem('preferredLanguage') || 'fr'; switchLanguage(savedLang); });
